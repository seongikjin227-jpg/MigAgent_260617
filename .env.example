# Copy this file to .env and fill in values for your environment.
# Windows PowerShell: Copy-Item .env.example .env

# =============================================================================
# Required
# =============================================================================

# Oracle DB connection
DB_USER=
DB_PASS=
DB_HOST=localhost
DB_PORT=1521
DB_SID=xe

# LLM
# LLM_PROVIDER: LLM 호출 방식입니다. OpenAI 호환 API면 openai, Anthropic API면 anthropic을 사용합니다.
LLM_PROVIDER=openai
# LLM_API_KEY: LLM API Key입니다. 기존 화면/스크립트 호환 때문에 OPEN_API_KEY도 지원하지만 보통 이 값을 사용합니다.
LLM_API_KEY=
# LLM_MODEL: 기본으로 먼저 시도할 모델명입니다.
LLM_MODEL=claude-haiku-4-5-20251001

# RAG embedding is required when SQL tuning and supplemental mapping search use vector search.
# RAG_EMBED_BASE_URL: embedding 서버 base URL입니다. /v1 또는 /v1/embeddings 형태 모두 허용됩니다.
RAG_EMBED_BASE_URL=
# RAG_EMBED_API_KEY: embedding 서버가 인증을 요구하지 않으면 비워둡니다.
RAG_EMBED_API_KEY=
# RAG_EMBED_MODEL: embedding 모델명입니다.
RAG_EMBED_MODEL=bge-m3

# SQL tuning rule catalog
TOBE_RULE_CATALOG_PATH=server/services/sql/data/rag/tobe_rule_catalog.json

# Required only when running the MyBatis XML parser.
MAPPER_XML_SOURCE_DIR=
ACTIVE_SQL_ID_TABLE=

# =============================================================================
# Optional
# =============================================================================

# Oracle optional settings
# Set when using Oracle Client thick mode.
ORACLE_CLIENT_PATH=
# Prefixes unqualified table names when set (applies to system tables like NEXT_MIG_INFO).
ORACLE_SCHEMA=
# Source schema for FR SQL/test validation context (e.g. SFAMIG).
# SQL validation prompts use this to qualify source-side physical tables when needed.
ORACLE_SCHEMA_SRC=
# Target schema for TO-BE SQL/test validation context (e.g. SFAADM).
# SQL pipeline DB sessions use this as CURRENT_SCHEMA by default.
ORACLE_SCHEMA_TGT=

# Target table names
MAPPING_RULE_TABLE=NEXT_MIG_INFO
MAPPING_RULE_DETAIL_TABLE=NEXT_MIG_INFO_DTL
RESULT_TABLE=NEXT_SQL_INFO

# LLM optional settings
# OPEN_API_KEY: 과거 코드/화면 호환용 alias입니다. LLM_API_KEY를 쓰면 보통 비워둬도 됩니다.
OPEN_API_KEY=
# LLM_BASE_URL: 사내 LLM gateway나 OpenAI-compatible endpoint 주소입니다. provider 기본 endpoint를 쓰면 비워둡니다.
LLM_BASE_URL=
# LLM_MAX_TOKENS: LLM 응답 최대 토큰 수입니다. 너무 작으면 SQL/JSON 응답이 잘릴 수 있습니다.
LLM_MAX_TOKENS=4096
# LLM_FALLBACK_MODELS: 기본 모델 실패 시 순서대로 재시도할 후보입니다.
# 적용 대상: Supervisor, DB Migration, SQL Conversion/Tuning/Formatting 내부 LLM 호출.
# fallback 조건: model not allow / model not found / 500 server error 등 모델 또는 서버 치명 오류.
# 제외 조건: read timeout, 일반 rate limit, 504 gateway timeout 등 일시적 지연 오류는 같은 모델 retry 대상으로 봅니다.
# Current fallback behavior: model access/not found errors, 5xx server errors,
# connection reset, temporarily unavailable, and bad gateway.
# Generic read timeout is excluded.
LLM_FALLBACK_MODELS=GLM-5.1,Qwen3.6-35B-A3B,Kimi-K2.5

# RAG and SQL tuning options
# RAG_EMBED_TIMEOUT_SEC: embedding HTTP 요청 timeout 초입니다.
RAG_EMBED_TIMEOUT_SEC=30
# COMPLEX_MAP_EXACT_MATCH_INCLUDE_ALL:
# true이면 NEXT_SQL_INFO.TARGET_TABLE과 NEXT_SQL_COMPLEX_MAP.FR_TABLE이 일치하는 보조 매핑룰은 전부 프롬프트에 넣습니다.
COMPLEX_MAP_EXACT_MATCH_INCLUDE_ALL=true
# COMPLEX_MAP_OTHER_TOP_K:
# TARGET_TABLE과 FR_TABLE이 다른 NEXT_SQL_COMPLEX_MAP 룰 중 source SQL과 유사한 룰을 RAG로 몇 개 추가할지 정합니다.
# 0이면 다른 FR_TABLE 보조 룰은 추가하지 않습니다.
COMPLEX_MAP_OTHER_TOP_K=2
# CORRECT_SQL_HINT_TOP_K: 과거 정답 SQL(TOBE/BIND/TEST correct SQL) RAG hint를 최대 몇 개 넣을지 정합니다.
CORRECT_SQL_HINT_TOP_K=2
# TOBE_SQL_TUNING_TOP_K: SQL Tuning RAG rule 후보를 최대 몇 개 넣을지 정합니다.
TOBE_SQL_TUNING_TOP_K=3
# TOBE_SQL_TUNING_MAX_ITERATIONS: tuning 반복 횟수입니다. 0이면 tuning LLM 호출을 건너뜁니다.
TOBE_SQL_TUNING_MAX_ITERATIONS=1

# Bind SQL pre-tuning options
# BIND_SQL_PRETUNING_ENABLED: true이면 긴 FR SQL이 실패했을 때 Bind SQL 생성 전에 한 번 단순화합니다.
BIND_SQL_PRETUNING_ENABLED=false
# BIND_SQL_PRETUNING_MIN_LENGTH: 이 길이 이상인 SQL만 pre-tuning 대상으로 봅니다.
BIND_SQL_PRETUNING_MIN_LENGTH=8000

# MyBatis XML parser options
XML_PARSER_DATA_DIR=server/services/sql/DATA
ACTIVE_SQL_ID_COLUMN=SQL_ID

# Supervisor options
# SUPERVISOR_JOB_BATCH_SIZE: poll_jobs가 내부 후보를 자를 때 쓰는 기본 batch size입니다.
SUPERVISOR_JOB_BATCH_SIZE=20
# *_JOB_BATCH_SIZE: Supervisor 한 cycle에서 registry에 올릴 agent별 job 수입니다.
# 현재 운영 정책은 순차 처리를 위해 SQL Conversion/Tuning/Formatting도 1개씩 처리합니다.
MIGRATION_JOB_BATCH_SIZE=1
SQL_CONVERSION_JOB_BATCH_SIZE=1
SQL_TUNING_JOB_BATCH_SIZE=1
SQL_FORMATTING_JOB_BATCH_SIZE=1
# SUPERVISOR_JOB_WAIT_SECONDS: job 1건 처리 후 다음 cycle까지 기다릴 시간입니다.
SUPERVISOR_JOB_WAIT_SECONDS=1
# SUPERVISOR_IDLE_WAIT_SECONDS: 처리할 job이 없을 때 다음 cycle까지 기다릴 시간입니다.
SUPERVISOR_IDLE_WAIT_SECONDS=30
# SUPERVISOR_MAX_WAIT_SECONDS: request_wait가 실제로 대기할 수 있는 최대 시간입니다.
SUPERVISOR_MAX_WAIT_SECONDS=300
# SQL conversion/tuning rows with BATCH_CNT at or above this value are not picked.
# Set 0 or less to disable the BATCH_CNT limit.
JOB_MAX_BATCH_COUNT=30
# LangGraph node transition limit for the long-running Supervisor loop.
SUPERVISOR_RECURSION_LIMIT=10000
MIG_KIND=DB_MIG
# DB_MIGRATION_MAX_ATTEMPTS: DB Migration 업무 retry 상한입니다. dependency WAITING은 batch count 증가 대상이 아닙니다.
DB_MIGRATION_MAX_ATTEMPTS=2
# Agent selection when using python main.py.
# If all four flags are false, the Supervisor runs all agents.
# If one or more flags are true, the Supervisor runs only the selected agents.
DB_MIGRATION_ONLY=false
SQL_CONVERSION_ONLY=true
SQL_TUNING_ONLY=false
SQL_FORMATTING_ONLY=false
